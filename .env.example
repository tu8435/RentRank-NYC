# RapidAPI / StreetEasy-style listing provider
RAPIDAPI_KEY=
RAPIDAPI_REALTY_HOST=st-easy-api.p.rapidapi.com
RAPIDAPI_REALTY_BASE_URL=https://st-easy-api.p.rapidapi.com
RAPIDAPI_REALTY_SEARCH_PATH=/search/rent
RAPIDAPI_REALTY_DETAIL_PATH=/rental_detailsbyid
RAPIDAPI_PER_PAGE=100
RAPIDAPI_BATCH_LOCATIONS=true
RAPIDAPI_MAX_REQUESTS=20

# Google Gemini qualitative scoring
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Google Maps commute checks
# Use demo to avoid billable Distance Matrix requests while testing.
GOOGLE_MAPS_API_KEY=demo

# Google Sheets / Drive output
# Use either OAuth or service-account auth.
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_TOKEN=secrets/google-oauth-token.json
GOOGLE_OAUTH_PORT=8080
GOOGLE_APPLICATION_CREDENTIALS=

# Optional NYC Open Data HPD lookup
NYC_OPEN_DATA_APP_TOKEN=

# Optional private local overrides.
# Keep real values only in your ignored .env file.
RENTRANK_PROFILE_PATH=
RENTRANK_WORKSPACE_PATH=
APARTMENT_RENTER_NAMES=
APARTMENT_RENTER_EMAILS=
APARTMENT_MOVE_IN=
APARTMENT_COMMUTE_DESTINATION=
APARTMENT_OUTREACH_APPLICANT_DETAILS=
APARTMENT_CREDIT_SCORE_NOTES=
